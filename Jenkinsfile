// https://www.jenkins.io/doc/book/pipeline/docker/
// https://www.jenkins.io/doc/book/pipeline/syntax/
pipeline {
  agent any
  options {
    timeout(time: 4, unit: 'HOURS')
  }
  stages {
  }
  post {
    cleanup {
      deleteDir()  /* clean up our workspace */
    }
  }
}
